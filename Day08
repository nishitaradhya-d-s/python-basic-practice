#leap year or not
year= int (input("enter a year:"))
if(year%4==0):
    print(year,"is a leap year")
else:
    print(year, "is not a leap year")

#multiple tables
for i in range (1,11):
    for j in range (1,11):
        product=i*j
        print(i,"*",j ,"=", product)

